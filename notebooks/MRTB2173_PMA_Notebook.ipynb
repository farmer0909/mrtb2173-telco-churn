      "source": "---\n## Q3(a) \u2013 Automated Validation Script\n> **Screenshot the output** \u2192 paste into Word as Figure 8"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": "# validate_data.py \u2013 run inline for screenshot evidence\nimport sys\n\ndef validate_dataset(df_input):\n    df_check = df_input.copy()\n    errors = []\n\n    # Check 1: Missing values\n    df_check['TotalCharges'] = pd.to_numeric(df_check['TotalCharges'], errors='coerce')\n    missing = df_check.isnull().sum()\n    missing = missing[missing > 0]\n    if not missing.empty:\n        errors.append(f\"Missing values found: {missing.to_dict()}\")\n\n    # Check 2: Duplicate rows\n    dupes = df_check.duplicated().sum()\n    if dupes > 0:\n        errors.append(f\"Duplicate rows: {dupes}\")\n\n    # Check 3: Required columns\n    required = ['customerID','Churn','tenure','MonthlyCharges','TotalCharges']\n    missing_cols = [c for c in required if c not in df_check.columns]\n    if missing_cols:\n        errors.append(f\"Missing required columns: {missing_cols}\")\n\n    # Check 4: Negative tenure\n    if (df_check['tenure'] < 0).any():\n        errors.append(\"Negative tenure values detected\")\n\n    print(\"=\" * 50)\n    print(\"AUTOMATED DATA VALIDATION REPORT\")\n    print(\"=\" * 50)\n    if errors:\n        print(\"STATUS: VALIDATION FAILED\")\n        for e in errors:\n            print(f\"  [FAIL] {e}\")\n    else:\n        print(\"STATUS: ALL CHECKS PASSED \u2713\")\n    print(\"=\" * 50)\n\n# Test on RAW data (before cleaning)\nraw_df = pd.read_csv('WA_Fn-UseC_-Telco-Customer-Churn.csv')\nprint(\"\\n--- Running on RAW data ---\")\nvalidate_dataset(raw_df)\n\n# Test on CLEANED data\nclean_df = raw_df.copy()\nclean_df['TotalCharges'] = pd.to_numeric(clean_df['TotalCharges'], errors='coerce')\nclean_df['TotalCharges'].fillna(clean_df['TotalCharges'].median(), inplace=True)\nprint(\"\\n--- Running on CLEANED data ---\")\nvalidate_dataset(clean_df)",
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": "---\n## Q5(b) \u2013 Data Drift Analysis (PSI)\n> **Screenshot the output** \u2192 paste into Word as Figure 9"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": "def compute_psi(baseline, target, bins=10):\n    breakpoints = np.percentile(baseline, np.linspace(0, 100, bins + 1))\n    breakpoints = np.unique(breakpoints)\n    baseline_pct = np.histogram(baseline, bins=breakpoints)[0] / len(baseline)\n    target_pct   = np.histogram(target, bins=breakpoints)[0] / len(target)\n    baseline_pct = np.where(baseline_pct == 0, 0.0001, baseline_pct)\n    target_pct   = np.where(target_pct   == 0, 0.0001, target_pct)\n    psi = np.sum((target_pct - baseline_pct) * np.log(target_pct / baseline_pct))\n    return psi\n\n# Simulate 6-month future data with slight distribution shift\nnp.random.seed(42)\ntrain_charges = df_model['MonthlyCharges'].values  # already scaled\nfuture_charges = train_charges * 1.08 + np.random.normal(0, 0.1, len(train_charges))\n\npsi_value = compute_psi(train_charges, future_charges)\n\nprint(\"=\" * 50)\nprint(\"DATA DRIFT ANALYSIS \u2013 Population Stability Index (PSI)\")\nprint(\"=\" * 50)\nprint(f\"Feature     : MonthlyCharges\")\nprint(f\"PSI Value   : {psi_value:.4f}\")\nprint()\nif psi_value < 0.1:\n    status = \"No significant shift \u2013 model remains stable\"\nelif psi_value < 0.2:\n    status = \"Moderate shift \u2013 monitor closely\"\nelse:\n    status = \"Significant shift \u2013 consider retraining\"\nprint(f\"Interpretation: {status}\")\nprint()\nprint(\"PSI Reference:\")\nprint(\"  PSI < 0.10  \u2192 No significant change\")\nprint(\"  PSI 0.10\u20130.20 \u2192 Moderate change, monitor\")\nprint(\"  PSI > 0.20  \u2192 Significant change, retrain model\")\n\n# Plot distribution comparison\nfig, ax = plt.subplots(figsize=(9, 4))\nax.hist(train_charges, bins=40, alpha=0.6, color='steelblue', label='Training Data (Baseline)', density=True)\nax.hist(future_charges, bins=40, alpha=0.6, color='#E63946', label='Simulated Future Data (Target)', density=True)\nax.set_title(f'Figure 9: Data Drift \u2013 MonthlyCharges Distribution (PSI = {psi_value:.4f})',\n             fontsize=12, fontweight='bold')\nax.set_xlabel('MonthlyCharges (scaled)', fontsize=11)\nax.set_ylabel('Density', fontsize=11)\nax.legend()\nplt.tight_layout()\nplt.savefig('fig9_psi_drift.png', dpi=150, bbox_inches='tight')\nplt.show()",
      "outputs": [],
      "execution_count": null
    },
