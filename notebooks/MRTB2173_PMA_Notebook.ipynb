    {
      "cell_type": "code",
      "metadata": {},
      "source": "print(\"=\" * 60)\nprint(\"FEATURE ENGINEERING\")\nprint(\"=\" * 60)\n\n# Step 1: Fix TotalCharges and drop missing\ndf['TotalCharges'] = pd.to_numeric(df['TotalCharges'], errors='coerce')\ndf['TotalCharges'].fillna(df['TotalCharges'].median(), inplace=True)\n\n# Drop customerID (non-predictive)\ndf_model = df.drop('customerID', axis=1)\n\n# Step 1: Label encode binary columns\nbinary_cols = ['gender','Partner','Dependents','PhoneService','PaperlessBilling','Churn']\nle = LabelEncoder()\nfor col in binary_cols:\n    df_model[col] = le.fit_transform(df_model[col])\n\nprint(\"Step 1: Label encoding applied to:\", binary_cols)\nprint(df_model[binary_cols].head(3))\n\n# Step 2: One-hot encode multi-class categoricals\nmulti_cols = ['MultipleLines','InternetService','OnlineSecurity','OnlineBackup',\n              'DeviceProtection','TechSupport','StreamingTV','StreamingMovies',\n              'Contract','PaymentMethod']\ndf_model = pd.get_dummies(df_model, columns=multi_cols, drop_first=True)\n\nprint(f\"\\nStep 2: One-hot encoding applied. Shape after encoding: {df_model.shape}\")\nprint(\"New columns added:\", [c for c in df_model.columns if any(m in c for m in multi_cols)][:5], \"...\")\n\n# Step 3: Standard scaling of continuous features\nscaler = StandardScaler()\ndf_model[['tenure','MonthlyCharges','TotalCharges']] = scaler.fit_transform(\n    df_model[['tenure','MonthlyCharges','TotalCharges']])\n\nprint(\"\\nStep 3: StandardScaler applied to tenure, MonthlyCharges, TotalCharges\")\nprint(df_model[['tenure','MonthlyCharges','TotalCharges']].describe().round(3))",
      "outputs": [],
      "execution_count": null
    },
