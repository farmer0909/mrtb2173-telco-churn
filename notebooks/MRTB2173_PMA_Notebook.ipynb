      "source": "print(\"=\" * 60)\nprint(\"DATA QUALITY CHECK 2: Data Type Verification\")\nprint(\"=\" * 60)\nprint(\"\\nData types BEFORE fix (TotalCharges should be float64):\")\nprint(df.dtypes[['tenure','MonthlyCharges','TotalCharges']])\n\nprint(\"\\nData types AFTER fix:\")\ndf['TotalCharges'] = pd.to_numeric(df['TotalCharges'], errors='coerce')\nprint(df.dtypes[['tenure','MonthlyCharges','TotalCharges']])\n\nprint(\"\\n\")\nprint(\"=\" * 60)\nprint(\"DATA QUALITY CHECK 3: Duplicate Rows\")\nprint(\"=\" * 60)\nprint(f\"Duplicate rows found: {df.duplicated().sum()}\")\n\nprint(\"\\n\")\nprint(\"=\" * 60)\nprint(\"SUMMARY TABLE\")\nprint(\"=\" * 60)\nsummary = pd.DataFrame({\n    'Issue': ['Missing values (MNAR)', 'Wrong data type (object\u2192float)', 'Duplicate rows'],\n    'Column': ['TotalCharges', 'TotalCharges', 'All columns'],\n    'Count': [df['TotalCharges'].isnull().sum(), '1 column', df.duplicated().sum()],\n    'Method': ['pd.to_numeric + isnull()', 'df.info() / dtype check', 'df.duplicated().sum()']\n})\nprint(summary.to_string(index=False))",
